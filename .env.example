# ============================================================
# Smart Brew AI — 环境变量模板
# ============================================================
# 使用方法：
#   cp .env.example .env
#   然后编辑 .env 填入实际值
#
# ⚠️ .env 包含密钥，不会被提交到 Git
# ============================================================

# DeepSeek AI API Key（必填 — 用于 AI 分析和知识库问答）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# MySQL Root 密码（默认 root）
MYSQL_ROOT_PASSWORD=root

# EMQX Dashboard 密码（默认 admin）
EMQX_DASHBOARD_PASSWORD=admin
